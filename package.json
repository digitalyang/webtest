{
  "name": "webtest",
  "version": "1.0.0",
  "description": "Personal static site deployed with Cloudflare Workers and D1.",
  "scripts": {
    "normalize:images": "node scripts/normalize-portfolio-images.cjs",
    "generate:portfolio-thumbs": "node scripts/generate-portfolio-thumbnails.cjs",
    "generate:portfolio": "node scripts/generate-portfolio-manifest.cjs",
    "prebuild": "npm run generate:portfolio-thumbs && npm run generate:portfolio",
    "build": "next build",
    "test": "vitest run --environment jsdom",
    "dev": "next dev",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "version": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "d1:migrate:local": "wrangler d1 migrations apply webtest-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply webtest-db --remote"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digitalyang/webtest.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/digitalyang/webtest/issues"
  },
  "homepage": "https://github.com/digitalyang/webtest#readme",
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "dompurify": "^3.4.5",
    "marked": "^18.0.4",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5"
  }
}
