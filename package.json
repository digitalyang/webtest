{
  "name": "webtest",
  "version": "1.0.0",
  "description": "Personal static site deployed with Cloudflare Workers and D1.",
  "scripts": {
    "normalize:images": "node scripts/normalize-portfolio-images.js",
    "generate:portfolio": "node scripts/generate-portfolio-manifest.js",
    "prebuild": "node scripts/generate-portfolio-manifest.js",
    "build": "node scripts/build-static.js",
    "test": "vitest run --environment jsdom",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "version": "npm run build && wrangler versions upload",
    "d1:migrate:local": "wrangler d1 migrations apply webtest-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply webtest-db --remote"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digitalyang/webtest.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/digitalyang/webtest/issues"
  },
  "homepage": "https://github.com/digitalyang/webtest#readme",
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  },
  "dependencies": {
    "dompurify": "^3.4.5",
    "marked": "^18.0.4"
  }
}
